rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
      );

      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() >= 2 && data.displayName.size() <= 32
            && (data.createdAt is string || data.createdAt == null);
      }
    }

    // --- Pets ---
    match /pets/{petId} {
      allow list: if true;
      allow get: if true;
      
      allow create: if isValidId(petId) && isValidPet(incoming()) && (
        isOwner(incoming().ownerId) || 
        incoming().ownerId == 'community_seeder' // Allow seeding
      );

      allow update: if isValidId(petId) && isValidPet(incoming()) && (
        // Action: Increment stats (Public)
        (incoming().diff(existing()).affectedKeys().hasOnly(['viewCount', 'downloadCount']) && 
         (incoming().viewCount == existing().viewCount + 1 || incoming().downloadCount == existing().downloadCount + 1))
        ||
        // Action: Toggle Like
        (incoming().diff(existing()).affectedKeys().hasOnly(['likeCount']))
        ||
        // Action: Change owner display name (Restricted to owner)
        (isOwner(existing().ownerId) && incoming().diff(existing()).affectedKeys().hasOnly(['ownerName']))
        ||
        // Action: Reseed/Update by community_seeder
        (existing().ownerId == 'community_seeder' && incoming().ownerId == 'community_seeder')
      );

      allow delete: if isSignedIn() && (isOwner(existing().ownerId) || existing().ownerId == 'community_seeder');

      function isValidPet(data) {
        return data.ownerId is string && data.ownerId.size() <= 128
            && data.ownerName is string && data.ownerName.size() <= 64
            && data.displayName is string && data.displayName.size() <= 64
            && data.description is string && data.description.size() <= 1000
            && data.tags is list
            && data.spritesheetUrl is string && data.spritesheetUrl.size() <= 512
            && data.downloadUrl is string && data.downloadUrl.size() <= 600
            && data.uploadedAt is string
            && data.viewCount is int
            && data.downloadCount is int
            && data.likeCount is int
            && data.validationReport is map;
      }
    }

    // --- Likes ---
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(incoming().petId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
