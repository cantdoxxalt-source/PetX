# ── Database ───────────────────────────────────────────────────────────────────
# Provided automatically by Railway/Render PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=""

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="petxspace"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Optional: set if you enable public access on the R2 bucket (faster, no proxy)
# R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ── Solana ─────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"
# Generate new escrow keypair: solana-keygen new --no-bip39-passphrase -o escrow.json
# Fund with ~0.05 SOL to cover unlist/return fees
ESCROW_KEYPAIR="[...]"
ESCROW_PUBLIC_KEY=""

# ── Pinata IPFS ────────────────────────────────────────────────────────────────
PINATA_JWT=""

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=4000
FRONTEND_URL="https://petx.space"
CORS_ORIGIN="https://petx.space,https://www.petx.space"
# Optional: restrict cookie domain
# COOKIE_DOMAIN=".petx.space"

# ── Frontend (Vite — baked into bundle at build time) ─────────────────────────
# Set to your backend URL when frontend and backend are on different hosts
VITE_API_URL="https://api.petx.space"
VITE_SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"
VITE_SOLANA_CLUSTER="mainnet-beta"
