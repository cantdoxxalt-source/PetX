# ── Database ───────────────────────────────────────────────────────────────────
# Provided automatically by Railway PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=""

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="petxspace"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Optional: set if you enable public access on the R2 bucket (faster, no proxy)
# R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ── Solana ─────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"
# Fund escrow wallet with ~0.05 SOL to cover unlist fees
ESCROW_KEYPAIR="[...]"
ESCROW_PUBLIC_KEY=""

# ── Pinata IPFS ────────────────────────────────────────────────────────────────
PINATA_JWT=""

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=4000
# Set to your Railway domain after first deploy
FRONTEND_URL="https://your-app.up.railway.app"
CORS_ORIGIN="https://your-app.up.railway.app"

# ── Frontend (Vite — baked into bundle at build time) ─────────────────────────
# Leave blank — frontend and backend share the same Railway origin
VITE_API_URL=""
VITE_SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"
VITE_SOLANA_CLUSTER="mainnet-beta"
